# Copy to .env and fill locally. Never commit real secrets.

GITHUB_TOKEN=
GITHUB_ACTOR=

# OpenAI-compatible model endpoint. For a fine-tuned model, put the provider key
# here and the exact fine-tuned model id in LLM_MODEL.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=
LLM_SMALL_MODEL=
LLM_REASONING_MODEL=

CONTROLLER_DRY_RUN=true
CONTROLLER_WORKSPACE=..
CONTROLLER_STATE_DIR=.controller/state
CONTROLLER_MAX_ACTIVE_SPRINTS=1
CONTROLLER_MAX_ACTIVE_TARGETS=3
CONTROLLER_MAX_OPEN_HYPOTHESES=5
CONTROLLER_ALLOW_PUBLIC_COMMENTS=false
CONTROLLER_ALLOW_PR_CREATE=false
CONTROLLER_ALLOW_FORCE_PUSH=false
CONTROLLER_PUBLIC_ACTION_MODE=none
CONTROLLER_PUBLIC_PR_DRAFT_ONLY=true
CONTROLLER_PUBLIC_ACTION_COOLDOWN_HOURS=24
CONTROLLER_MAX_OPEN_CONTROLLER_PRS_PER_REPO=1
CONTROLLER_ALLOW_WORKER_EXECUTION=false
CONTROLLER_WORKER_TIMEOUT_SECONDS=1800
CONTROLLER_LOOP_INTERVAL_SECONDS=900
